---
layout: layouts/base.njk
title: Players
---

<div class="page-header">
  <h1>Players</h1>
</div>

<div class="page-header page-header--section" style="margin-top: 0;">
  <h2>Regulars</h2>
  <p class="page-subtitle">Attended two or more events this year</p>
</div>

<div class="member-grid">
  {% for member in players.members %}
  <div class="member-card" id="{{ member.name | slugify }}">
    <div class="member-avatar">
      {% if member.photo %}
      <img src="{{ member.photo | url }}" alt="{{ member.name }}">
      {% else %}
      <div class="member-avatar-placeholder">{{ member.name | first | upper }}</div>
      {% endif %}
    </div>
    <div class="member-info">
      <h2 class="member-name">{{ member.name }}{% if member.email %} <a class="member-email" href="mailto:{{ member.email }}" title="{{ member.email }}"><svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg></a>{% endif %}</h2>
      {% if member.role %}<div class="member-role">{{ member.role }}</div>{% endif %}
      {% if member.bmab_title or member.bmab %}
      <div class="member-bmab-title">
        {% if member.bmab_title %}{% if 'GM' in member.bmab_title %}Grandmaster{% else %}Master{% endif %}{% endif %}
        {% if member.bmab_title and member.bmab %} | {% endif %}
        {% if member.bmab %}<a class="member-bmab" href="{{ member.bmab }}" target="_blank" rel="noopener">BMAB ↗</a>{% endif %}
      </div>
      {% endif %}
      {% if member.og %}
      <div class="member-og"><span class="member-og-label">opengammon</span><span class="member-og-handle">{{ member.og }}</span></div>
      {% endif %}
      {% if member.rating %}
      <div class="member-rating">Rating: {{ member.rating }}</div>
      {% endif %}
      {% if member.bio %}
      <p class="member-bio">{{ member.bio }}</p>
      {% endif %}
      {% if member.joined %}
      <div class="member-joined">Member since {{ member.joined | dateFormatMonth }}</div>
      {% endif %}
    </div>
  </div>
  {% endfor %}
</div>

{% if players.guests | length %}
<div class="page-header page-header--section">
  <h2>Guests</h2>
  <p class="page-subtitle">Attended one event this year</p>
</div>

<div class="member-grid">
  {% for guest in players.guests %}
  <div class="member-card member-card--guest" id="{{ guest.name | slugify }}">
    <div class="member-avatar">
      {% if guest.photo %}
      <img src="{{ guest.photo | url }}" alt="{{ guest.name }}">
      {% else %}
      <div class="member-avatar-placeholder">{{ guest.name | first | upper }}</div>
      {% endif %}
    </div>
    <div class="member-info">
      <h2 class="member-name">{{ guest.name }}{% if guest.email %} <a class="member-email" href="mailto:{{ guest.email }}" title="{{ guest.email }}"><svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg></a>{% endif %}</h2>
      {% if guest.role %}<div class="member-role">{{ guest.role }}</div>{% endif %}
      {% if guest.bmab_title or guest.bmab %}
      <div class="member-bmab-title">
        {% if guest.bmab_title %}{% if 'GM' in guest.bmab_title %}Grandmaster{% else %}Master{% endif %}{% endif %}
        {% if guest.bmab_title and guest.bmab %} | {% endif %}
        {% if guest.bmab %}<a class="member-bmab" href="{{ guest.bmab }}" target="_blank" rel="noopener">BMAB ↗</a>{% endif %}
      </div>
      {% endif %}
      {% if guest.og %}
      <div class="member-og"><span class="member-og-label">opengammon</span><span class="member-og-handle">{{ guest.og }}</span></div>
      {% endif %}
      {% if guest.rating %}
      <div class="member-rating">Rating: {{ guest.rating }}</div>
      {% endif %}
      {% if guest.bio %}
      <p class="member-bio">{{ guest.bio }}</p>
      {% endif %}
    </div>
  </div>
  {% endfor %}
</div>
{% endif %}
