---
layout: layouts/base.njk
title: Tournaments
permalink: /tournaments/
---

<div class="page-header">
  <h1>Tournaments</h1>
</div>

{# Collect upcoming (date >= today) and past (date < today) meetings #}
{% set upcoming = [] %}
{% set past = [] %}
{% for meeting in meetings %}
  {% if meeting.date >= site.today %}
    {% set upcoming = (upcoming.push(meeting), upcoming) %}
  {% else %}
    {% set past = (past.push(meeting), past) %}
  {% endif %}
{% endfor %}

<section class="tournaments-section">
  <h2 class="tournaments-section-title">Upcoming</h2>
  {% if upcoming.length == 0 %}
  <p class="tournaments-empty">No upcoming meetings scheduled.</p>
  {% else %}
  <div class="meetings">
    {% for meeting in upcoming %}
    <div class="meeting-card" id="meeting-upcoming-{{ loop.index }}">
      <button class="meeting-header" aria-expanded="false">
        <div class="meeting-header-left">
          <span class="meeting-date">{{ meeting.date | dateFormat }}</span>
          <span class="meeting-location">{{ meeting.location }}</span>
        </div>
        <div class="meeting-header-right">
          <span class="meeting-match-count">
            {%- if meeting.rounds -%}
              {{ meeting.rounds | meetingTally | length }} players
            {%- else -%}
              No results yet
            {%- endif -%}
          </span>
          <span class="meeting-chevron" aria-hidden="true">▾</span>
        </div>
      </button>
      {% if meeting.rounds %}
      <div class="meeting-body" hidden>
        <table class="tally-table">
          <thead>
            <tr>
              <th>Player</th>
              <th>Record</th>
            </tr>
          </thead>
          <tbody>
            {% for p in meeting.rounds | meetingTally %}
            <tr>
              <td>{{ p.name }}</td>
              <td class="tally-record">
                {{ p.wins }}-{{ p.losses }}{% if p.byes %} <span class="tally-bye">({{ p.byes }} bye)</span>{% endif %}
              </td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
        {% for round in meeting.rounds %}
        <div class="round-section">
          <button class="round-header" aria-expanded="false">
            <span>Round {{ loop.index }} Results</span>
            <span class="round-chevron" aria-hidden="true">▾</span>
          </button>
          <div class="round-body" hidden>
            <table class="match-table">
              <thead>
                <tr>
                  <th>Player 1</th>
                  <th>Player 2</th>
                </tr>
              </thead>
              <tbody>
                {% for match in round.matches %}
                <tr>
                  <td class="{{ 'is-winner' if match.w == 1 and match.p2 }}">{{ match.p1 }}</td>
                  <td class="{{ 'is-winner' if match.w == 2 }}">
                    {%- if match.bye or not match.p2 -%}
                      <em>bye</em>
                    {%- else -%}
                      {{ match.p2 }}
                    {%- endif -%}
                  </td>
                </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        </div>
        {% endfor %}
      </div>
      {% endif %}
    </div>
    {% endfor %}
  </div>
  {% endif %}
</section>

<section class="tournaments-section">
  <h2 class="tournaments-section-title">Past Results</h2>
  {% if past.length == 0 %}
  <p class="tournaments-empty">No past results yet.</p>
